# Django
DJANGO_SECRET_KEY=change-me-to-a-random-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database (used in production / VPS — dev uses SQLite)
DATABASE_URL=postgres://seo_tool:seo_tool@localhost:5432/seo_tool

# Redis / Celery (used in production — dev runs tasks synchronously)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0

# DataForSEO API
DATAFORSEO_LOGIN=your-login
DATAFORSEO_PASSWORD=your-password

# CORS (production — comma-separated origins)
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api
